# Local configuration for TDP Rust project
# Copy this file to config.toml and fill in your values
#
# Settings can be overridden at runtime using environment variables:
# - TDP_DATA_ACCESS__EMBED__OPENAI__API_KEY=sk-...
# - TDP_DATA_ACCESS__VECTOR__QDRANT__URL=http://localhost:6334
# - TDP_DATA_PROCESSING__TDPS_MARKDOWN_ROOT=/path/to/tdps_markdown
#
# All environment variable keys use the TDP_ prefix and __ (double underscore) to separate nested levels

[data_access]
run = "dev"

[data_access.embed.openai]
model_name = "text-embedding-3-small"
api_key = ""  # Add your OpenAI API key here or override via TDP_DATA_ACCESS__EMBED__OPENAI__API_KEY

# FastEmbed as alternative (local, no API key needed)
[data_access.embed.fastembed]
model_name = "BGEBaseENV15Q"

# Qdrant vector database (gRPC endpoint — use port 6334, not 6333)
[data_access.vector.qdrant]
url = "http://localhost:6334"
embedding_size = 1536  # must match the embed model's output dimension — changing this requires re-running initialize

# SQLite metadata database
[data_access.metadata.sqlite]
filename = "data/my_sqlite.db"

# SQLite activity/logging database
[data_access.activity.sqlite]
filename = "data/activity.db"

[data_processing]
tdps_markdown_root = "/path/to/tdps_markdown/"
