<mxfile>
  <diagram name="Architecture Overview" id="arch">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="TDP Rust — Architecture Overview" style="text;html=1;fontSize=20;fontStyle=1;align=center;verticalAlign=middle;fillColor=none;strokeColor=none;fontColor=#333333;" vertex="1" parent="1">
          <mxGeometry x="160" y="10" width="680" height="40" as="geometry"/>
        </mxCell>

        <!-- External Systems layer -->
        <mxCell id="ext_group" value="External Systems" style="swimlane;startSize=30;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;fontColor=#333333;container=1;collapsible=0;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="920" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="qdrant" value="Qdrant&#xa;(Vector DB)" style="shape=cylinder3;size=10;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="ext_group">
          <mxGeometry x="30" y="35" width="110" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="openai" value="OpenAI API&#xa;(Embeddings)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;size=12;" vertex="1" parent="ext_group">
          <mxGeometry x="180" y="35" width="130" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="sqlite" value="SQLite&#xa;(Metadata + Activity)" style="shape=cylinder3;size=10;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="ext_group">
          <mxGeometry x="350" y="35" width="140" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="markdown_files" value="Markdown TDP&#xa;Files (corpus)" style="shape=document;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;size=0.15;" vertex="1" parent="ext_group">
          <mxGeometry x="530" y="33" width="120" height="57" as="geometry"/>
        </mxCell>
        <mxCell id="browser" value="Browser&#xa;(SvelteKit)" style="shape=mxgraph.basic.rounded_frame;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="ext_group">
          <mxGeometry x="690" y="35" width="110" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="ai_client" value="AI Assistant&#xa;(MCP Client)" style="shape=mxgraph.basic.rounded_frame;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;" vertex="1" parent="ext_group">
          <mxGeometry x="810" y="35" width="100" height="55" as="geometry"/>
        </mxCell>

        <!-- Server Layer -->
        <mxCell id="server_group" value="Server Crates (thin wrappers)" style="swimlane;startSize=28;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=13;fontColor=#333333;container=1;collapsible=0;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="190" width="920" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="web_crate" value="&lt;b&gt;web&lt;/b&gt;&#xa;Axum REST :50000&#xa;+ static files" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="server_group">
          <mxGeometry x="160" y="35" width="200" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="mcp_crate" value="&lt;b&gt;mcp&lt;/b&gt;&#xa;rmcp server :50001 (open)&#xa;:50002 (OAuth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="server_group">
          <mxGeometry x="560" y="35" width="200" height="55" as="geometry"/>
        </mxCell>

        <!-- API Layer -->
        <mxCell id="api_group" value="Shared Handlers" style="swimlane;startSize=28;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;fontColor=#333333;container=1;collapsible=0;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="920" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="api_crate" value="&lt;b&gt;api&lt;/b&gt;  —  search, list_tdps, list_teams, list_leagues,&#xa;get_tdp_markdown, get_toc, get_paragraph, get_table, get_image, get_abstract, activity" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="api_group">
          <mxGeometry x="60" y="35" width="800" height="55" as="geometry"/>
        </mxCell>

        <!-- Business Logic Layer -->
        <mxCell id="logic_group" value="Business Logic" style="swimlane;startSize=28;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;fontColor=#333333;container=1;collapsible=0;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="450" width="920" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="data_processing" value="&lt;b&gt;data_processing&lt;/b&gt;&#xa;Searcher (hybrid semantic+keyword),&#xa;chunking, IDF computation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="logic_group">
          <mxGeometry x="60" y="35" width="360" height="55" as="geometry"/>
        </mxCell>
        <mxCell id="configuration" value="&lt;b&gt;configuration&lt;/b&gt;&#xa;TOML + TDP_* env overrides,&#xa;client factory helpers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="logic_group">
          <mxGeometry x="500" y="35" width="360" height="55" as="geometry"/>
