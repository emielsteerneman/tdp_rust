          <mxGeometry x="700" y="40" width="180" height="50" as="geometry"/>
        </mxCell>

        <!-- Domain Types Layer -->
        <mxCell id="ds_group" value="Domain Types (no I/O)" style="swimlane;startSize=28;fillColor=#F0F0F0;strokeColor=#999999;fontStyle=1;fontSize=13;fontColor=#333333;container=1;collapsible=0;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="720" width="920" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="data_structures" value="&lt;b&gt;data_structures&lt;/b&gt;  —  TDPName, League, TeamName, IDF, MarkdownTDP, FrontMatter, ContentItem, ContentType, TocEntry, Chunk" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F0F0F0;strokeColor=#999999;fontSize=11;" vertex="1" parent="ds_group">
