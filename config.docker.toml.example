# Docker configuration for TDP Rust project
# Copy this file to config.docker.toml and fill in your values
# This config is baked into Docker images at build time
#
# Users can override specific settings using environment variables:
# - TDP_DATA_ACCESS__EMBED__OPENAI__API_KEY=sk-...
# - TDP_DATA_ACCESS__EMBED__OPENAI__MODEL_NAME=text-embedding-3-large
# - TDP_DATA_PROCESSING__TDPS_MARKDOWN_ROOT=/path/to/tdps_markdown
#
# All environment variable keys use the TDP_ prefix and __ (double underscore) to separate nested levels

[data_access]

[data_access.embed.openai]
model_name = "text-embedding-3-small"
api_key = ""  # Add your OpenAI API key here or override via TDP_DATA_ACCESS__EMBED__OPENAI__API_KEY

# Qdrant vector database
# When using docker-compose: connects via Docker network (service name)
# When using existing Qdrant on host: override via environment variable
[data_access.vector.qdrant]
url = "http://qdrant:6334"    # gRPC endpoint (use port 6334, not 6333)
embedding_size = 1536        # Fixed with pre-filled snapshot

# SQLite metadata database (baked into image)
[data_access.metadata.sqlite]
filename = "/app/data/metadata.db"

# Team registry (baked into image)
[data_access.teams.sqlite]
filename = "/app/data/teams.db"
master_password = ""  # Only consumed on first DB init
salt = ""

[data_processing]
tdps_markdown_root = "/data/tdps_markdown"

# SQLite activity/logging database (persisted via Docker volume)
[event_processing.activity.sqlite]
filename = "/app/activity_data/activity.db"

# Optional: Telegram notifications
# [event_processing.telegram]
# bot_token = ""
# chat_id = ""
