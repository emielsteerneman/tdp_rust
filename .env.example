# Docker environment configuration
# Copy this file to .env and fill in your values
# These variables will be loaded by docker-compose and passed to the services

# OpenAI API key (required for OpenAI embeddings)
# Get your key from https://platform.openai.com/api-keys
TDP_OPENAI_API_KEY=sk-proj-your-api-key-here

# (Optional) Override embedding model
# TDP_DATA_ACCESS__EMBED__OPENAI__MODEL_NAME=text-embedding-3-large

# (Optional) Override TDPS JSON root path (must be mounted as volume in docker-compose.yml)
# TDP_DATA_PROCESSING__TDPS_JSON_ROOT=/data/tdps
